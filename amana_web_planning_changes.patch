+            $payload = $this->webhookBuilder->buildDelete($absence);
+            SynchroniserGoogleCalendar::dispatchSync($payload, 'delete', 'absence');
+            Log::info('[AbsencesController] Synchronisation Google Calendar (delete)', ['id' => $absence->id]);
