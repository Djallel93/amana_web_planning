# ═══════════════════════════════════════════════════════════════════════════════════
# .deploy-now/amana_web_planning/.env.template
#
# Template for the production .env file used on IONOS.
# The template-renderer-action reads this file, substitutes any $VARIABLE placeholder
# with a matching secret/env value injected during the GitHub Actions build,
# and writes the result as `.env` into the deployment folder
#
# $IONOS_* variables are NOT secrets you define yourself — they are provided
# automatically by the IONOS Deploy Now platform (database credentials, mail
# credentials, app URL) based on the webspace/database resources linked
# to this project.
# ════════════════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────
# APPLICATION IDENTITY & CORE BEHAVIOR
# ───────────────────────────────────────────────────────────────────────────

APP_NAME="AMANA Planning"
# Display name of the app — used in email "From" name, page titles, etc.

APP_ENV=production
# Laravel environment mode. Controls error verbosity, caching behavior,
# and is checked throughout the framework (e.g. disables debug pages).

APP_DEBUG=false
# When true, Laravel shows detailed stack traces on errors (NEVER true
# in production — leaks file paths, queries, env values to visitors).

APP_KEY=
# Encryption key used by Laravel for encrypted cookies, sessions,
# Crypt::encrypt(), password reset tokens, etc.
# MUST be present (even empty) for `php artisan key:generate` to work —
# the command looks for this exact line and replaces its value.
# Left empty here; generated during the build step.

APP_TIMEZONE=UTC
# Default PHP/Laravel timezone for date() and Carbon operations.

APP_URL=$IONOS_APP_URL
# Base URL of the deployed app, used by Laravel to generate absolute
# URLs (links in emails, asset() helper, etc.). Injected by IONOS
# based on the actual webspace domain assigned to this deployment.


# ───────────────────────────────────────────────────────────────────────────
# LOCALIZATION
# ───────────────────────────────────────────────────────────────────────────

APP_LOCALE=en
# Default locale for Laravel's translation strings.

APP_FALLBACK_LOCALE=en
# Locale used if a translation string is missing in APP_LOCALE.

APP_FAKER_LOCALE=en_US
# Locale used by the Faker library (factories/seeders) — irrelevant
# in production but harmless to leave set.


# ───────────────────────────────────────────────────────────────────────────
# MAINTENANCE MODE
# ───────────────────────────────────────────────────────────────────────────

APP_MAINTENANCE_DRIVER=file
# How Laravel tracks "maintenance mode" (php artisan down/up).
# 'file' = a simple file flag on disk; works without DB access,
# which matters if the DB itself is what's broken.

# APP_MAINTENANCE_STORE=database
# Alternative driver (commented out) — would track maintenance state
# in the DB instead of a file. Not used here.


# ───────────────────────────────────────────────────────────────────────────
# DATABASE CONNECTION
# ───────────────────────────────────────────────────────────────────────────

DB_CONNECTION=mysql
# Database driver Laravel will use (mysql/mariadb in this case).

DB_HOST=$IONOS_DB_HOST
# Hostname of the MySQL/MariaDB server, provided by IONOS for the
# database resource linked to this project.

DB_PORT=3306
# Standard MySQL/MariaDB port.

DB_DATABASE=$IONOS_DB_NAME
# Name of the database schema to connect to, provided by IONOS.

DB_USERNAME="$IONOS_DB_USERNAME"
# Database username, provided by IONOS.

DB_PASSWORD="$IONOS_DB_PASSWORD"
# Database password, provided by IONOS (kept secret, never logged).


# ───────────────────────────────────────────────────────────────────────────
# SESSIONS
# ───────────────────────────────────────────────────────────────────────────

SESSION_DRIVER=database
# Where Laravel stores session data. 'database' is used here because
# shared IONOS hosting can have unreliable file permissions for the
# 'file' driver — requires the `sessions` table (created by migration).

SESSION_LIFETIME=120
# Minutes of inactivity before a session expires (2 hours here).

SESSION_ENCRYPT=false
# Whether session payloads are encrypted at rest in storage.

SESSION_PATH=/
# Cookie path scope — '/' means valid across the entire site.

SESSION_DOMAIN=null
# Cookie domain scope — null lets the browser default to the current host.


# ───────────────────────────────────────────────────────────────────────────
# FILE STORAGE, QUEUE & CACHE
# ───────────────────────────────────────────────────────────────────────────

FILESYSTEM_DISK=local
# Default filesystem disk for Storage:: calls (local disk, not S3 etc.).

QUEUE_CONNECTION=sync
# Where queued jobs (e.g. EnvoyerWebhookMake, email notifications) are
# processed. 'sync' runs jobs immediately inline (no worker needed);
# switch to 'database' if you want jobs queued in the `jobs` table instead.

CACHE_STORE=file
# Where Laravel's cache facade stores cached values — uses the `cache`
# table (created by migration) instead of file-based caching.
# NOTE: CACHE_DRIVER below is the older/legacy key name for the same
# setting in some Laravel versions — having both set to different
# values (database vs file) is likely unintentional. Pick one.

CACHE_PREFIX=
# Optional prefix for cache keys, useful to avoid collisions if multiple
# apps share the same cache store. Left empty = no prefix.


# ───────────────────────────────────────────────────────────────────────────
# PHP RUNTIME TUNING
# ───────────────────────────────────────────────────────────────────────────

PHP_CLI_SERVER_WORKERS=4
# Number of worker processes for `php artisan serve` (Laravel's
# built-in dev server) — not relevant to production but kept for
# consistency with the local .env.example.

BCRYPT_ROUNDS=12
# Cost factor for bcrypt password hashing. Higher = slower to compute
# but more resistant to brute-force. 12 is Laravel's secure default.


# ───────────────────────────────────────────────────────────────────────────
# MAIL / SMTP
# ───────────────────────────────────────────────────────────────────────────

MAIL_MAILER=smtp
# Transport used to send emails — SMTP in production (vs 'log' locally).

MAIL_SCHEME=null
# Encryption scheme for SMTP (e.g. tls) — set via IONOS secrets in
# the GitHub Actions env block (MAIL_SCHEME: tls), not hardcoded here.

MAIL_HOST=$IONOS_MAIL_HOST
# SMTP server hostname, provided by IONOS.

MAIL_PORT=$IONOS_MAIL_PORT
# SMTP server port, provided by IONOS.

MAIL_USERNAME="$IONOS_MAIL_USERNAME"
# SMTP authentication username, provided by IONOS.

MAIL_PASSWORD="$IONOS_MAIL_PASSWORD"
# SMTP authentication password, provided by IONOS (kept secret).

MAIL_FROM_ADDRESS=$IONOS_MAIL_FROM_ADDRESS
# Default "From" email address used when sending notifications.

MAIL_FROM_NAME="${APP_NAME}"
# Default "From" display name — reuses APP_NAME defined above.


# ───────────────────────────────────────────────────────────────────────────
# MAKE.COM WEBHOOK INTEGRATION
# ───────────────────────────────────────────────────────────────────────────

MAKE_WEBHOOK_URL="$MAKE_WEBHOOK_URL"
# URL Make.com scenario listens on. Read by config/services.php and
# used by the EnvoyerWebhookMake job to push planning/event updates
# to Google Calendar. Injected via GitHub Actions secrets at build time
# (see MAKE_WEBHOOK_URL in the workflow's `env:` block) — left blank
# in the template itself since the renderer doesn't see a $VAR here.

MAKE_WEBHOOK_APIKEY="$MAKE_WEBHOOK_APIKEY"
# API key sent in the `x-make-apikey` header on every webhook call.
# Same as above — actual value comes from the build-time secret,
# not from this template file directly.


# ───────────────────────────────────────────────────────────────────────────
# LOGGING
# ───────────────────────────────────────────────────────────────────────────

LOG_CHANNEL=stack
# The logging "channel" Laravel uses by default — 'stack' combines
# one or more channels (configured below via LOG_STACK).

LOG_STACK=single
# Which channel(s) the 'stack' driver writes to — 'single' = one log
# file (storage/logs/laravel.log).

LOG_DEPRECATIONS_CHANNEL=null
# Channel used for PHP/Laravel deprecation warnings — null disables
# separate logging of these (they still flow into LOG_CHANNEL if at all).

LOG_LEVEL=debug
# Minimum severity level that gets logged. 'debug' logs everything,
# including verbose internal detail — consider 'error' or 'warning'
# for production to reduce log noise/size and avoid leaking detail.


# ───────────────────────────────────────────────────────────────────────────
# MISC / LEGACY (not actively used by this app, kept for compatibility)
# ───────────────────────────────────────────────────────────────────────────

BROADCAST_DRIVER=log
# Laravel event broadcasting driver. 'log' just writes broadcast
# events to the log instead of pushing them anywhere — effectively
# a no-op unless broadcasting is wired up elsewhere.

MEMCACHED_HOST=127.0.0.1
# Host for Memcached, only relevant if a cache/session driver above
# is switched to 'memcached'. Currently unused (cache uses database/file,
# sessions use database).
